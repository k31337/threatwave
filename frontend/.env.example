# Copy to .env.local to override. All values are exposed in the built bundle
# (Vite only inlines VITE_-prefixed vars) — do NOT put real secrets here.

# Base URL of the API. Empty = same origin, which is what you want both in dev
# (Vite proxies /api to the API) and in production (FastAPI serves this bundle).
VITE_API_BASE=

# Optional API key sent as the X-API-Key header. This is CASUAL GATING, not a
# secret: it ships in the bundle and is readable by anyone loading the page. The
# real protection for a public deployment is the API's rate limiting.
VITE_API_KEY=
