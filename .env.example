# Copy this file to .env and fill in real values. Never commit .env.

# --- Neo4j (graph store) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# Value consumed by the neo4j container as NEO4J_AUTH=neo4j/<password>.

# --- PostgreSQL + pgvector (embeddings, reserved for a later phase) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=threatweave
POSTGRES_USER=threatweave
POSTGRES_PASSWORD=

# --- AlienVault OTX ingestion connector ---
OTX_API_KEY=
OTX_BASE_URL=https://otx.alienvault.com/api/v1

# --- LLM provider (used by `threatweave ingest-doc`) ---
# provider: none | openai | ollama
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# Cost / safety controls for extraction calls.
LLM_MAX_INPUT_CHARS=48000
LLM_MAX_OUTPUT_TOKENS=1024
LLM_MAX_RETRIES=2
# Embeddings (semantic similarity).
LLM_EMBED_MODEL=text-embedding-3-small
LLM_EMBED_DIM=1536

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# Graph backend: "neo4j" (default) or "memory" for a no-Docker demo.
GRAPH_BACKEND=neo4j
# When GRAPH_BACKEND=memory, seed the store from data/samples on startup.
SEED_SAMPLE=false

# Vector backend for semantic similarity: none | memory | pgvector
VECTOR_BACKEND=none
